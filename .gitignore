# ============================================================
#  ChartLie Detector — Master .gitignore
# ============================================================

# --- System & OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# --- IDEs & Editors ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iws
*.iml
*.ipr
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# --- Virtual Environments ---
venv/
.venv/
env/
ENV/
venv.bak/
env.bak/

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
secrets.json
secrets.yaml
secrets.yml

# --- Python Build & Cache ---
__pycache__/
*.py[cod]
*$py.class
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Node / Frontend Build & Dependencies ---
node_modules/
frontend/node_modules/
frontend/dist/
dist/
.vite/
.eslintcache
.oxlintcache

# --- Project-Specific Transient Paths ---
backend/uploads/
backend/reports/
backend/datasets/
backend/app/output/
backend/download_misviz.py.cache
*.pkl
*.joblib
*.log
logs/
temp/
tmp/
